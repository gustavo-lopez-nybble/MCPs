{
    "mcpServers": {
      "filesystem": {
        "command": "bun",
        "args": ["run", "/PATH/TO/MCPs/packages/mcp-filesystem/src/index.ts"],
        "env": {
          "FS_ROOT_DIR": "/path/to/project",
          "FS_ALLOWED_EXTENSIONS": ".ts,.tsx,.json,.md",
          "FS_MAX_FILE_KB": "100"
        }
      }
    }
}
